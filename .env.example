# Browser-visible public configuration only
PUBLIC_SITE_URL=https://daytradingbot.net
PUBLIC_API_URL=https://api.daytradingbot.net

# API runtime secrets must be installed through systemd credentials on Namecheap.
DATABASE_URL=postgresql://daytradingbot@localhost/daytradingbot
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
LICENSE_SIGNING_PRIVATE_KEY_PEM_FILE=/run/credentials/daytradingbot-api.service/license-signing-key
LICENSE_SECRET_PEPPER_FILE=/run/credentials/daytradingbot-api.service/license-secret-pepper
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=licenses@daytradingbot.net
SMTP_PASSWORD_FILE=
