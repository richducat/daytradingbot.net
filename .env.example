# Browser-visible public configuration only
PUBLIC_SITE_URL=https://daytradingbot.net
PUBLIC_API_URL=https://api.daytradingbot.net
VITE_API_BASE_URL=https://api.daytradingbot.net

# Namecheap shared-hosting API. Store each secret file outside public_html.
NODE_ENV=production
API_HOST=0.0.0.0
DATABASE_PROVIDER=mysql
DATABASE_URL_FILE=/home/CPANEL_USER/.daytradingbot-secrets/database-url
STRIPE_SECRET_KEY_FILE=/home/CPANEL_USER/.daytradingbot-secrets/stripe-secret-key
STRIPE_WEBHOOK_SECRET_FILE=/home/CPANEL_USER/.daytradingbot-secrets/stripe-webhook-secret
STRIPE_PRICE_ID=price_REPLACE_WITH_LIVE_PRICE
# Keep false until the signed and notarized Mac installer is published.
CHECKOUT_ENABLED=false
COMMERCE_ENCRYPTION_KEY_FILE=/home/CPANEL_USER/.daytradingbot-secrets/commerce-encryption-key
LICENSE_SIGNING_PRIVATE_KEY_PEM_FILE=/home/CPANEL_USER/.daytradingbot-secrets/license-signing-key.pem
LICENSE_SECRET_PEPPER_FILE=/home/CPANEL_USER/.daytradingbot-secrets/license-secret-pepper
SMTP_URL_FILE=/home/CPANEL_USER/.daytradingbot-secrets/smtp-url
LICENSE_EMAIL_FROM=licenses@daytradingbot.net
SUPPORT_EMAIL=support@daytradingbot.net
MACOS_DOWNLOAD_URL=https://releases.daytradingbot.net/stable/DayTradingBot-macos-universal.dmg
