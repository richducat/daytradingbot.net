{
  "name": "@daytradingbot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "run:web-worker": "node dist/run-worker.js",
    "provision:owner-license": "tsx src/provision-owner-license.ts",
    "verify:mysql": "tsx src/verify-mysql-commercial.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "fastify": "5.10.0",
    "mysql2": "3.22.6",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "stripe": "22.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
